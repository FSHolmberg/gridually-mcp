  "vviq_test": {
    "title": "VVIQ — Vividness of Visual Imagery Questionnaire",
    "description": "The VVIQ is the standard test for measuring the vividness of your mental imagery. It asks you to imagine various scenes (a friend's face, a sunrise, a shop front) and rate how vivid the image is on a scale of 1-5.",
